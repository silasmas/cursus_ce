APP_NAME="PHILA-CE"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Kinshasa

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

# YOUTUBE_MIRROR_COOKIES_BROWSER=chrome


LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Analytics portail Inertia (none | plausible | ga) — /admin exclu
ANALYTICS_DRIVER=none
PLAUSIBLE_DOMAIN=
PLAUSIBLE_SCRIPT_URL=https://plausible.io/js/script.js
GA_MEASUREMENT_ID=

# Sondage fidèle (après X semaines depuis la première inscription)
MEMBER_SURVEY_ENABLED=true
MEMBER_SURVEY_WEEKS_AFTER_ENROLLMENT=4
MEMBER_SURVEY_SNOOZE_DAYS=7

# Filament Browser Notifications (Web Push admin)
# Générer avec : php artisan browser-notifications:install (serveur Linux recommandé)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="${APP_URL}"

# Filament Export Cleanup (exports tableaux)
FILAMENT_EXPORT_CLEANUP_ENABLED=true
FILAMENT_EXPORT_CLEANUP_RETENTION_HOURS=72

# Filament AI Writer — OpenAI (recommandé si vous avez un compte OpenAI)
AI_WRITER_PROVIDER=openai
OPENAI_API_KEY=
AI_WRITER_MODEL=gpt-4o

# Zoom Server-to-Server OAuth (création automatique de lien RDV mentor)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Déploiement HTTP production (POST migrations + seeders + Shield)
# Générer : php -r "echo bin2hex(random_bytes(32));"
DEPLOYMENT_TOKEN=
DEPLOYMENT_ROUTE=run-production-deploy
DEPLOYMENT_RATE_LIMIT=6
DEPLOYMENT_SEEDER_KEY=production-starter

# Google Calendar OAuth (création automatique de lien Google Meet)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE="${APP_TIMEZONE}"

# Windows/Laragon: requis si webpush:vapid échoue (OpenSSL config introuvable)
# OPENSSL_CONF=C:\laragon\bin\php\php-8.3.28-Win32-vs16-x64\extras\ssl\openssl.cnf
AI_WRITER_MAX_TOKENS=2048

# Alternatives :
# AI_WRITER_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# AI_WRITER_MODEL=claude-sonnet-4-20250514
